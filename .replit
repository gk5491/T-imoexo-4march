modules = ["web", "nodejs-20", "php-8.2"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Game"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PHP Backend"

[[workflows.workflow]]
name = "Start Game"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "PHP Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "php -S 0.0.0.0:8080 -t server"
waitForPort = 8080

[[ports]]
localPort = 3001
externalPort = 3001
exposeLocalhost = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 34467
externalPort = 6800

[[ports]]
localPort = 35549
externalPort = 8000

[[ports]]
localPort = 35811
externalPort = 9000

[[ports]]
localPort = 36581
externalPort = 8099

[[ports]]
localPort = 38125
externalPort = 8081

[[ports]]
localPort = 38811
externalPort = 5173

[[ports]]
localPort = 39691
externalPort = 3003

[[ports]]
localPort = 40223
externalPort = 5000

[[ports]]
localPort = 43381
externalPort = 4200

[[ports]]
localPort = 44281
externalPort = 3002

[[ports]]
localPort = 45325
externalPort = 6000

[[ports]]
localPort = 46529
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]
